# Server-only Supabase connection values.
# Keep these values out of NEXT_PUBLIC_* variables.
APP_ORIGIN=http://localhost:3000
SUPABASE_URL=
SUPABASE_PUBLISHABLE_KEY=

# Prefer SUPABASE_SECRET_KEY. Use the legacy service-role key only when the
# project has not migrated to Supabase secret keys yet.
SUPABASE_SECRET_KEY=
# SUPABASE_SERVICE_ROLE_KEY=

# Server-only operational controls.
NOTES_WRITE_ENABLED=false
